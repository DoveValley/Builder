# Block direct access to .git and other dotfiles/dotfolders if this repo
# was ever deployed with .git still present (it should be removed before
# going live, but this is a safety net).
<IfModule mod_rewrite.c>
    RewriteRule "(^|/)\.(?!well-known)" - [F,L]
</IfModule>
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Optional: pretty URLs for landing pages.
# With this enabled, a page with slug "about-us" is reachable at
# /about-us in addition to /page.php?slug=about-us.
#
# If your host doesn't support .htaccess rewrites (or this causes issues),
# you can safely delete this file - landing pages will still work via
# /page.php?slug=your-slug.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Protect per-site data directories and sensitive JSON files from direct web access
    RewriteRule ^sites/[^/]+/data(/.*)?$ - [F,L]
    RewriteRule ^sites/[^/]+/meta\.json$ - [F,L]
    RewriteRule ^sites/[^/]+/deploy\.json$ - [F,L]
    RewriteRule ^sites/[^/]+/deploy_manifest\.json$ - [F,L]
    # Block directory listing of sites/ root
    RewriteRule ^sites/?$ - [F,L]
    # Block root-level data/ directory (media.json, variation.json, site.json, etc.)
    RewriteRule ^data(/.*)?$ - [F,L]

    # Serve sitemap.xml and robots.txt via PHP so shortcodes resolve automatically
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^robots\.txt$  robots.php  [L]

    # Blog listing (with optional ?tag=&p=) and single posts
    RewriteRule ^blog/?$ blog.php [L,QSA]
    RewriteRule ^blog/([a-zA-Z0-9-]+)/?$ blog.php?slug=$1 [L,QSA]

    # Don't rewrite requests for real files or directories
    # (e.g. /admin, /assets, /uploads, /data, /index.php, /page.php).
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # /some-slug -> /page.php?slug=some-slug
    RewriteRule ^([a-zA-Z0-9-]+)/?$ page.php?slug=$1 [L,QSA]

    # Nested pretty URLs (plugin-routed matrix pages, e.g. /texas/houston/aetna)
    # -> page.php?path=full/path. The route_request hook decides; unclaimed paths
    # fall through to a normal 404. (Single-segment slugs hit the rule above first.)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-zA-Z0-9/_-]+)/?$ page.php?path=$1 [L,QSA]
</IfModule>
