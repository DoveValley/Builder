*.log
.DS_Store
*.tmp

# FTP credentials — never commit. deploy.json lives at the SITE ROOT (the path
# the code actually reads, ACTIVE_SITE_DIR/deploy.json); the data/ path below is
# kept as a belt-and-suspenders guard for any legacy location.
sites/*/deploy.json
sites/*/data/deploy.json

# Multisite campaign data (holds FTP credentials) — never commit.
# Ignore the whole dir: fail-safe, so no future file inside can ever leak.
sites/*/multisite/

# Generated static output and the multisite regression baseline — local artifacts, not source.
output/
_multisite_baseline/

# Test Lab scratch uploads (transient, auto-pruned)
uploads/lab/
uploads/convo/

# Test Lab -> build locked hero-overlay style (set per-environment via the UI)
multisite/hero_style.json

# Generation backups (created by generate.py on each landing regen)
sites/*/data/pages/*.bak

# Ad-hoc data backups (.bak, .bak2, .bak-pest, etc.) left by rework/clone tools
sites/*/data/*.bak
sites/*/data/*.bak[0-9]
sites/*/data/*.bak-*

# Python bytecode cache
__pycache__/
*.pyc

# Anthropic API key (secret — never commit)
.ai_key
config/plesk.json
admin/infra/config/servers.json
admin/infra/config/cloudflare.json
admin/infra/config/registrar.json
admin/infra/config/fleet.json
admin/infra/state/
admin/infra/config/domains.json
